# Server
PORT=5000
NODE_ENV=development

# MongoDB — Atlas, local mongod, or use `memory` in development only (no install; data lost on restart)
MONGODB_URI=mongodb://127.0.0.1:27017/education-hub
# MONGODB_URI=memory

# Google Sheets API (Service Account)
# Set to false for local API testing without credentials (leads still save to MongoDB).
GOOGLE_SHEETS_ENABLED=true

# Share the target spreadsheet with the service account email as Editor.
GOOGLE_SHEET_ID=your_spreadsheet_id_here
# Optional: A1 notation range for append (first row should be your header row)
GOOGLE_SHEET_RANGE=Sheet1!A:G

GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the private key from the JSON; use \n for newlines or real newlines in quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
